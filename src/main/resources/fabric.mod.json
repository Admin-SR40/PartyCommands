{
  "schemaVersion": 1,
  "id": "partycommands",
  "version": "${version}",
  "name": "Party Commands",
  "description": "Standalone party commands mod. Type !command directly in chat without /pc prefix.",
  "authors": ["Admin_SR40"],
  "license": "MIT",
  "icon": "assets/partycommands/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.partycommands.PartyCommandsMod"
    ]
  },
  "mixins": [
    {
      "config": "partycommands.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": ">=1.21",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=1.13.0",
    "yet_another_config_lib_v3": ">=3.8.0"
  }
}
